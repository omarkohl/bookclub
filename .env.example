# HTTP port the server listens on
BOOKCLUB_PORT=8080

# URL secret for member access: http://localhost:8080/{BOOKCLUB_CLUB_SECRET}/
# Change this to something unguessable before deploying
BOOKCLUB_CLUB_SECRET=your-club-secret-here

# URL secret for admin access: http://localhost:8080/{BOOKCLUB_CLUB_SECRET}/admin/{BOOKCLUB_ADMIN_SECRET}/
# Change this to something unguessable before deploying
BOOKCLUB_ADMIN_SECRET=your-admin-secret-here

# Path to the SQLite database file
# When using Docker, keep this inside the mounted volume (e.g. /data/bookclub.db)
BOOKCLUB_DB_PATH=bookclub.db
